{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Deep Research Agent",
  "version": "0.1.0",
  "identifier": "dev.deepresearchagent.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix ../../apps/gui-web run dev -- --port 5173",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm --prefix ../../apps/gui-web run build",
    "frontendDist": "../../../apps/gui-web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Deep Research Agent",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png"],
    "targets": "appimage"
  }
}
