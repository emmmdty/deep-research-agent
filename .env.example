# LLM provider
LLM_PROVIDER=openai_compatible
LLM_MODEL_NAME=MiniMax-M2.5
LLM_API_KEY=replace_with_provider_key
LLM_BASE_URL=https://api.minimaxi.com/v1
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# Optional provider-specific keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
ANTHROPIC_COMPATIBLE_API_KEY=
ANTHROPIC_COMPATIBLE_BASE_URL=

# Search
SEARCH_BACKEND=tavily
TAVILY_API_KEY=replace_with_tavily_key
MAX_SEARCH_RESULTS=5

# Research runtime
MAX_RESEARCH_LOOPS=3
RESEARCH_PROFILE=default
RESEARCH_CONCURRENCY=3
SOURCE_POLICY_MODE=company_broad
ENABLED_SOURCES=web,github,arxiv
ENABLED_CAPABILITY_TYPES=builtin,skill,mcp
SKILL_PATHS=
MCP_CONFIG_PATH=
MCP_SERVERS=[]
CASE_STUDY_OFFICIAL_DOMAINS=openai.com,anthropic.com,langchain.com,microsoft.com,learn.microsoft.com,aws.amazon.com,cloud.google.com,salesforce.com,ibm.com,huggingface.co

# Storage and artifacts
WORKSPACE_DIR=workspace
BUNDLE_EMISSION_ENABLED=true
BUNDLE_OUTPUT_DIRNAME=bundles
JOB_RUNTIME_DIRNAME=research_jobs
JOB_HEARTBEAT_INTERVAL_SECONDS=2
JOB_STALE_TIMEOUT_SECONDS=15
CONNECTOR_SUBSTRATE_ENABLED=true
SNAPSHOT_STORE_DIRNAME=snapshots
MEMORY_BACKEND=sqlite

# Logging
LOG_LEVEL=INFO
