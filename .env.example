# LLM 配置（MiniMax 为默认 Provider）
LLM_PROVIDER=minimax
LLM_MODEL_NAME=MiniMax-M2.5
LLM_API_KEY=your_minimax_api_key_here
LLM_BASE_URL=https://api.minimaxi.com/v1
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# 备选：DeepSeek
# LLM_PROVIDER=deepseek
# LLM_MODEL_NAME=deepseek-chat
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 备选：Agicto
# LLM_PROVIDER=agicto
# AGICTO_API_KEY=your_agicto_api_key_here

# 搜索配置
SEARCH_BACKEND=tavily
TAVILY_API_KEY=your_tavily_api_key_here

# 研究流程配置
MAX_RESEARCH_LOOPS=3
MAX_SEARCH_RESULTS=5
RESEARCH_PROFILE=default
RESEARCH_CONCURRENCY=3
ENABLED_CAPABILITY_TYPES=builtin,skill,mcp
SKILL_PATHS=
MCP_CONFIG_PATH=
MCP_SERVERS=[]
CASE_STUDY_OFFICIAL_DOMAINS=openai.com,anthropic.com,langchain.com,microsoft.com,learn.microsoft.com,aws.amazon.com,cloud.google.com,salesforce.com,ibm.com,huggingface.co
ENABLED_SOURCES=web,github,arxiv
ENABLED_COMPARATORS=ours,gptr,odr,alibaba
JUDGE_MODEL=
WORKSPACE_DIR=workspace
MEMORY_BACKEND=sqlite
GPT_RESEARCHER_PYTHON=

# 外部 comparator（按需启用）
OPEN_DEEP_RESEARCH_COMMAND=
OPEN_DEEP_RESEARCH_REPORT_DIR=
ALIBABA_RUNNER_MODE=command
ALIBABA_COMMAND=
ALIBABA_REPORT_DIR=
GEMINI_ENABLED=false
GEMINI_ALLOWLIST_REQUIRED=true
GEMINI_COMMAND=
GEMINI_REPORT_DIR=

# 日志
LOG_LEVEL=INFO
