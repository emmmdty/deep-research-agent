{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deep-research-agent.local/schemas/job-checkpoint.schema.json",
  "title": "JobCheckpoint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "checkpoint_id",
    "job_id",
    "stage",
    "sequence",
    "loop_count",
    "created_at",
    "next_stage",
    "state_payload"
  ],
  "properties": {
    "checkpoint_id": { "type": "string", "minLength": 1 },
    "job_id": { "type": "string", "minLength": 1 },
    "stage": {
      "type": "string",
      "enum": [
        "created",
        "clarifying",
        "planned",
        "collecting",
        "normalizing",
        "extracting",
        "claim_auditing",
        "synthesizing",
        "rendering",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "sequence": { "type": "integer", "minimum": 1 },
    "loop_count": { "type": "integer", "minimum": 0 },
    "created_at": { "type": "string", "format": "date-time" },
    "next_stage": {
      "type": "string",
      "enum": [
        "created",
        "clarifying",
        "planned",
        "collecting",
        "normalizing",
        "extracting",
        "claim_auditing",
        "synthesizing",
        "rendering",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "state_payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
