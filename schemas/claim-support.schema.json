{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deep-research-agent.local/schemas/claim-support.schema.json",
  "title": "ClaimSupportEdge",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "edge_id",
    "claim_id",
    "evidence_id",
    "relation",
    "confidence"
  ],
  "properties": {
    "edge_id": {
      "type": "string",
      "minLength": 1
    },
    "claim_id": {
      "type": "string",
      "minLength": 1
    },
    "evidence_id": {
      "type": "string",
      "minLength": 1
    },
    "source_id": {
      "type": "string"
    },
    "snapshot_id": {
      "type": "string"
    },
    "locator": {
      "type": "object",
      "additionalProperties": true
    },
    "relation": {
      "type": "string",
      "enum": [
        "supports",
        "partially_supports",
        "contradicts",
        "context_only"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "grounding_status": {
      "type": "string",
      "enum": [
        "grounded",
        "missing_evidence",
        "missing_source",
        "missing_snapshot",
        "missing_locator",
        "missing_excerpt",
        "unknown"
      ]
    },
    "notes": {
      "type": "string"
    }
  }
}
