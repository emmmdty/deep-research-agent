{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "benchmark",
    "title",
    "adapter_mode",
    "role",
    "status",
    "started_at",
    "completed_at",
    "output_root",
    "task_count",
    "completed_count",
    "blocked_count",
    "failed_count",
    "official_metrics",
    "internal_metrics",
    "artifacts",
    "notes",
    "integrity_guards",
    "environment"
  ],
  "properties": {
    "benchmark": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "adapter_mode": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "blocked",
        "failed"
      ]
    },
    "split": {
      "type": [
        "string",
        "null"
      ]
    },
    "subset": {
      "type": [
        "string",
        "null"
      ]
    },
    "bucket": {
      "type": [
        "string",
        "null"
      ]
    },
    "started_at": {
      "type": "string"
    },
    "completed_at": {
      "type": "string"
    },
    "output_root": {
      "type": "string"
    },
    "config_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "dataset_manifest_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "task_count": {
      "type": "integer",
      "minimum": 0
    },
    "completed_count": {
      "type": "integer",
      "minimum": 0
    },
    "blocked_count": {
      "type": "integer",
      "minimum": 0
    },
    "failed_count": {
      "type": "integer",
      "minimum": 0
    },
    "official_metrics": {
      "type": "object"
    },
    "internal_metrics": {
      "type": "object"
    },
    "integrity_report": {
      "type": [
        "string",
        "null"
      ]
    },
    "artifacts": {
      "type": "object"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "search_backend": {
      "type": [
        "string",
        "null"
      ]
    },
    "judge_backend": {
      "type": [
        "string",
        "null"
      ]
    },
    "integrity_guards": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "environment": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
