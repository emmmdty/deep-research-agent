{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deep-research-agent.local/schemas/claim.schema.json",
  "title": "Claim",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "claim_id",
    "text",
    "criticality",
    "uncertainty",
    "status"
  ],
  "properties": {
    "claim_id": {
      "type": "string",
      "minLength": 1
    },
    "text": {
      "type": "string",
      "minLength": 1
    },
    "criticality": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "uncertainty": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "supported",
        "partially_supported",
        "contradicted",
        "unsupported",
        "unverifiable"
      ]
    },
    "placeholder": {
      "type": "boolean"
    },
    "section_ref": {
      "type": "string"
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
