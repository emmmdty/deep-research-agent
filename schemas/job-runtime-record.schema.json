{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deep-research-agent.local/schemas/job-runtime-record.schema.json",
  "title": "JobRuntimeRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "job_id",
    "topic",
    "status",
    "current_stage",
    "created_at",
    "updated_at",
    "attempt_index",
    "cancel_requested",
    "report_path",
    "report_bundle_path",
    "trace_path",
    "runtime_path",
    "source_profile",
    "budget",
    "policy_overrides",
    "connector_health",
    "audit_gate_status",
    "critical_claim_count",
    "blocked_critical_claim_count",
    "audit_graph_path",
    "review_queue_path",
    "metadata"
  ],
  "properties": {
    "job_id": { "type": "string", "minLength": 1 },
    "topic": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "current_stage": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "attempt_index": { "type": "integer", "minimum": 1 },
    "retry_of": { "type": ["string", "null"] },
    "cancel_requested": { "type": "boolean" },
    "worker_pid": { "type": ["integer", "null"], "minimum": 1 },
    "worker_lease_id": { "type": ["string", "null"] },
    "last_heartbeat_at": { "type": ["string", "null"], "format": "date-time" },
    "active_checkpoint_id": { "type": ["string", "null"] },
    "report_path": { "type": "string", "minLength": 1 },
    "report_bundle_path": { "type": "string", "minLength": 1 },
    "trace_path": { "type": "string", "minLength": 1 },
    "runtime_path": { "type": "string", "minLength": 1 },
    "source_profile": { "type": "string", "minLength": 1 },
    "budget": {
      "type": "object",
      "additionalProperties": true
    },
    "policy_overrides": {
      "type": "object",
      "additionalProperties": true
    },
    "connector_health": {
      "type": "object",
      "additionalProperties": true
    },
    "audit_gate_status": { "type": "string", "minLength": 1 },
    "critical_claim_count": { "type": "integer", "minimum": 0 },
    "blocked_critical_claim_count": { "type": "integer", "minimum": 0 },
    "audit_graph_path": { "type": "string" },
    "review_queue_path": { "type": "string" },
    "error": { "type": ["string", "null"] },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
