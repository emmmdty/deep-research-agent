{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "benchmark",
    "task_id",
    "status",
    "prompt",
    "official_metrics",
    "internal_metrics",
    "notes",
    "metadata"
  ],
  "properties": {
    "benchmark": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "blocked",
        "failed"
      ]
    },
    "prompt": {
      "type": "string"
    },
    "prediction": {
      "type": [
        "string",
        "null"
      ]
    },
    "expected_answer": {
      "type": [
        "string",
        "null"
      ]
    },
    "official_metrics": {
      "type": "object"
    },
    "internal_metrics": {
      "type": "object"
    },
    "blocked_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
