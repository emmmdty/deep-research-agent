{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "benchmark",
    "status",
    "guards",
    "findings",
    "summary"
  ],
  "properties": {
    "benchmark": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "not_applicable",
        "passed",
        "blocked",
        "failed"
      ]
    },
    "guards": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "summary": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
