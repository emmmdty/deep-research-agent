{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deep-research-agent.local/schemas/evidence-fragment.schema.json",
  "title": "EvidenceFragment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_id",
    "snapshot_id",
    "source_id",
    "locator",
    "excerpt",
    "extraction_method"
  ],
  "properties": {
    "evidence_id": {
      "type": "string",
      "minLength": 1
    },
    "snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "source_id": {
      "type": "string",
      "minLength": 1
    },
    "locator": {
      "type": "object",
      "additionalProperties": true
    },
    "excerpt": {
      "type": "string"
    },
    "extraction_method": {
      "type": "string",
      "minLength": 1
    }
  }
}
